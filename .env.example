# Server port
PORT=4200

# APNs Push Notifications (iOS)
APNS_KEY=                # .p8 key content (paste the entire PEM block)
# APNS_KEY_PATH=         # Or: path to .p8 key file (APNS_KEY takes priority)
APNS_KEY_ID=             # 10-character Key ID
APNS_TEAM_ID=            # 10-character Team ID
APNS_BUNDLE_ID=          # App bundle identifier (e.g., com.example.app)
APNS_ENVIRONMENT=production  # "production" or "development"

# Model configurations are managed via UI or ~/.codeclaws/models.json
# No hardcoded API keys needed here
